{
    "name": "frontlines",
    "experienceName": "Frontlines",
    "version": "0.0.1",
    "type": "module",
    "description": "Battlefield Frontlines",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "init": "node scripts/init.js",
        "update": "node scripts/update.js",
        "refresh-ai": "node scripts/generate-ai-context.js",
        "build": "bf6-portal-bundler --entrypoint ./src/index.ts --outDir ./dist",
        "export-thumbnail": "node scripts/export-thumbnail.js",
        "minify-spatials": "node scripts/minify-all-spatials.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --no-error-on-unmatched-pattern --write '**/*.{js,json,md,mjs,ts}'",
        "deploy": "npm run build && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump patch",
        "deploy:patch": "npm run deploy",
        "deploy:minor": "npm run build && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump minor",
        "deploy:major": "npm run build && node scripts/deploy.js --script dist/bundle.ts --strings dist/bundle.strings.json --versionBump major"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/The0zzy/bf6-portal-frontlines"
    },
    "keywords": [
        "template",
        "portal",
        "battlefield",
        "battlefield-6",
        "bf6"
    ],
    "author": "The0zzy, andy6170, mancour",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/The0zzy/bf6-portal-frontlines/issues"
    },
    "homepage": "https://github.com/The0zzy/bf6-portal-frontlines#readme",
    "devDependencies": {
        "@bf6mods/portal": "^1.1.0",
        "@clack/prompts": "^1.5.1",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "bf6-portal-bundler": "^1.4.1",
        "bf6-portal-mod-types": "^3.1.0",
        "bf6-portal-utils": "^9.2.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "prettier": "^3.8.3",
        "sharp": "^0.34.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.60.1"
    },
    "templateVersion": "1.7.0"
}
